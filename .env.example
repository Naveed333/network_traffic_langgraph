# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith Observability (get your key at https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=network-traffic-prediction

# Model Configuration
MODEL_NAME=gpt-4o
MAX_TOKENS=4096
TEMPERATURE=0.1

# Pipeline Control
MAX_ITERATIONS=2
CONVERGENCE_THRESHOLD=10

# Context Window
CONTEXT_WINDOW_LIMIT=128000
CONTEXT_WINDOW_GUARD_PCT=0.8

# Data
DATA_PATH=data/traffic_data.csv
